{
  "name": "slides",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "npm run build:oop && npm run build:composition && npm run build:oop-review",
    "build:oop": "node --max-old-space-size=1536 ./node_modules/.bin/slidev build oop.md --base /python/oop/ --out dist/python/oop",
    "build:composition": "node --max-old-space-size=1536 ./node_modules/.bin/slidev build composition-polymorphism.md --base /python/composition-polymorphism/ --out dist/python/composition-polymorphism",
    "build:oop-review": "node --max-old-space-size=1536 ./node_modules/.bin/slidev build oop-review.md --base /python/oop-review/ --out dist/python/oop-review",
    "dev": "slidev --open",
    "dev:oop": "slidev oop.md --open",
    "dev:composition": "slidev composition-polymorphism.md --open",
    "dev:oop-review": "slidev oop-review.md --open",
    "export": "slidev export"
  },
  "dependencies": {
    "@phosphor-icons/vue": "^2.2.1",
    "@shikijs/transformers": "^4.0.2",
    "@slidev/cli": "^52.14.2",
    "@slidev/theme-default": "latest",
    "@slidev/theme-seriph": "latest",
    "vue": "^3.5.29"
  }
}
